<Window x:Class="ABeNT.OutputFormsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Berichtsformulare verwalten" Height="680" Width="960"
        WindowStartupLocation="CenterOwner"
        MinHeight="500" MinWidth="700"
        Background="{StaticResource BackgroundPage}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Universal-Prompt Button -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <Polygon Points="0,10 5,0 10,10" Fill="{StaticResource AccentYellow}" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <Button x:Name="BtnUniversalPrompt" Content="Universal-Prompt anzeigen / bearbeiten"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="14,8"
                    Click="BtnUniversalPrompt_Click"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="180"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- Formularliste -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,1,0" Padding="0,0,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Berichtsformulare" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlue}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <ListBox x:Name="LstForms" Grid.Row="1"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="LstForms_SelectionChanged"
                             Background="{StaticResource CardBackground}"
                             BorderBrush="{StaticResource BorderLight}"
                             BorderThickness="1"
                             Margin="0,0,0,12"/>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button x:Name="BtnAdd" Content="Hinzufügen"
                                Style="{StaticResource FilledAccentButtonStyle}"
                                Padding="14,6" FontSize="12"
                                Margin="0,0,8,0"
                                Click="BtnAdd_Click"/>
                        <Button x:Name="BtnRemove" Content="Entfernen"
                                Style="{StaticResource SubtleButtonStyle}"
                                Padding="14,6" FontSize="12"
                                IsEnabled="False"
                                Click="BtnRemove_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Formular-Detail -->
            <Grid Grid.Column="1" Margin="18,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PanelFormDetail" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="Formular bearbeiten" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <Rectangle Width="16" Height="3" Fill="{StaticResource AccentCoral}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Id (eindeutig, z. B. orthopaedie):" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtId" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Anzeigename:" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtDisplayName" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Beschreibung (optional):" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtDescription" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,18" Height="56" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource AccentYellow}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Prompts pro ABeNT-Abschnitt (leer = Standard verwenden)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>

                        <TextBlock Text="A (Anamnese):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,3"/>
                        <TextBox x:Name="TxtPromptA" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,8" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <TextBlock Text="Be (Befund):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,3"/>
                        <TextBox x:Name="TxtPromptBe" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,8" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <TextBlock Text="N (Diagnose):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,3"/>
                        <TextBox x:Name="TxtPromptN" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,8" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <TextBlock Text="ICD-10 (Codierung):" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,3"/>
                        <TextBox x:Name="TxtPromptIcd10" Style="{StaticResource BauhausTextBoxStyle}" Margin="0,0,0,12" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="0,10,0,0"
                        BorderBrush="{StaticResource BorderLight}"
                        BorderThickness="0,1,0,0"
                        Visibility="{Binding ElementName=PanelFormDetail, Path=Visibility}">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnSaveForm" Content="Formular speichern"
                                Style="{StaticResource FilledAccentButtonStyle}"
                                Padding="16,8" FontSize="13"
                                Margin="0,0,10,0"
                                Click="BtnSaveForm_Click"/>
                        <Button x:Name="BtnSaveAndTest" Content="Speichern und Testen"
                                Style="{StaticResource FilledAccentButtonStyle}"
                                Padding="16,8" FontSize="13"
                                Margin="0,0,10,0"
                                Click="BtnSaveAndTest_Click"/>
                        <Button x:Name="BtnGeneratePrompts" Content="Prompts generieren"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="16,8" FontSize="13"
                                Margin="0,0,10,0"
                                Click="BtnGeneratePrompts_Click"/>
                        <Button x:Name="BtnRestoreDefault" Content="Standard wiederherstellen"
                                Style="{StaticResource SubtleButtonStyle}"
                                Padding="16,8" FontSize="13"
                                Visibility="Collapsed"
                                Click="BtnRestoreDefault_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Fußzeile -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,14,0,0">
            <Button x:Name="BtnClose" Content="Schließen"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="20,8"
                    HorizontalAlignment="Right"
                    Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
