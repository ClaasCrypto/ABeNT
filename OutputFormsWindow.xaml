<Window x:Class="ABeNT.OutputFormsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Berichtsformulare verwalten" Height="680" Width="960"
        WindowStartupLocation="CenterOwner"
        MinHeight="500" MinWidth="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Oben: Universal-Prompt -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Button x:Name="BtnUniversalPrompt" Content="Universal-Prompt anzeigen / bearbeiten"
                    Padding="10,6" HorizontalAlignment="Left"
                    Click="BtnUniversalPrompt_Click"/>
        </StackPanel>
        
        <!-- Mitte: Liste links, Detail rechts -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- Links: Formulare-Liste -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Berichtsformulare" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox x:Name="LstForms" DisplayMemberPath="DisplayName"
                             SelectionChanged="LstForms_SelectionChanged"
                             MinHeight="200" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnAdd" Content="Hinzufügen" Width="95" Height="28" Margin="0,0,5,0" Click="BtnAdd_Click"/>
                        <Button x:Name="BtnRemove" Content="Entfernen" Width="95" Height="28" IsEnabled="False" Click="BtnRemove_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Rechts: Detail (nur sichtbar wenn Formular ausgewählt) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="15,0,0,0">
                <StackPanel x:Name="PanelFormDetail" Visibility="Collapsed">
                    <TextBlock Text="Formular bearbeiten" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Id (eindeutig, z. B. orthopaedie):" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtId" Margin="0,0,0,10" Padding="6,4" FontSize="12"/>
                    
                    <TextBlock Text="Anzeigename:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDisplayName" Margin="0,0,0,10" Padding="6,4" FontSize="12"/>
                    
                    <TextBlock Text="Beschreibung (optional):" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDescription" Margin="0,0,0,15" Padding="6,4" FontSize="12" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                    
                    <TextBlock Text="Prompts pro ABeNT-Abschnitt (leer = Standard verwenden)" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <TextBlock Text="A (Anamnese):" FontSize="11" Margin="0,6,0,2"/>
                    <TextBox x:Name="TxtPromptA" Margin="0,0,0,6" Padding="6,4" FontSize="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    
                    <TextBlock Text="Be (Befund):" FontSize="11" Margin="0,6,0,2"/>
                    <TextBox x:Name="TxtPromptBe" Margin="0,0,0,6" Padding="6,4" FontSize="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    
                    <TextBlock Text="N (Diagnose):" FontSize="11" Margin="0,6,0,2"/>
                    <TextBox x:Name="TxtPromptN" Margin="0,0,0,6" Padding="6,4" FontSize="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    
                    <TextBlock Text="T (Therapie):" FontSize="11" Margin="0,6,0,2"/>
                    <TextBox x:Name="TxtPromptT" Margin="0,0,0,15" Padding="6,4" FontSize="11" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BtnSaveForm" Content="Formular speichern" Width="140" Height="32" Margin="0,0,10,0" Click="BtnSaveForm_Click"/>
                        <Button x:Name="BtnRestoreDefault" Content="Standard wiederherstellen" Width="180" Height="32" Visibility="Collapsed" Click="BtnRestoreDefault_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <Button x:Name="BtnClose" Content="Schließen" Width="100" Height="30" HorizontalAlignment="Right" Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
