<Window x:Class="ABeNT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ABeNT"
        mc:Ignorable="d"
        Title="ABeNT" Height="700" Width="1400"
        MinHeight="600" MinWidth="1000"
        Background="{StaticResource BackgroundPage}">
    <Window.Resources>
        <Style x:Key="ControlButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}"/>
        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="NoteActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="200"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <!-- Karten-Header (warm) -->
        <Style x:Key="CardHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardHeaderBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="18,12"/>
        </Style>
        <!-- Karten-Container -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <!-- Abschnittstitel -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <!-- ReadOnly TextBox (Ergebnisfelder) -->
        <Style x:Key="ResultTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Open Sans, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="MinHeight" Value="80"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300" MinWidth="250"/>
        </Grid.ColumnDefinitions>
        
        <!-- ═══════════════════════════════════════════
             Links: Steuerung und Aktion
             ═══════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Bereich Steuerung (Links oben) -->
            <Border Grid.Row="0" 
                    Background="{StaticResource CardHeaderBackground}" 
                    BorderBrush="{StaticResource BorderLight}" 
                    BorderThickness="0,0,1,1"
                    Padding="20,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Image Source="Assets/logo.png" Height="36" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ABeNT" 
                                   FontSize="26" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Berichtsformular (Fachrichtung):" 
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbSubjectForm" 
                              Style="{StaticResource ComboBoxStyle}"
                              DisplayMemberPath="DisplayName"
                              HorizontalAlignment="Stretch"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Cursor="Hand" MouseDown="BtnManageForms_Click">
                        <TextBlock Text="&#x2699;" FontSize="14" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Berichtsformulare verwalten" TextDecorations="Underline" FontSize="12" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Bericht erstellen mit:" 
                               Style="{StaticResource FieldLabel}"
                               Margin="0,14,0,5"/>
                    <CheckBox x:Name="ChkAnamnese" 
                              Content="Anamnese" 
                              Style="{StaticResource CheckBoxStyle}"
                              IsChecked="True" IsEnabled="False"/>
                    <CheckBox x:Name="ChkBefund" 
                              Content="Befund" 
                              Style="{StaticResource CheckBoxStyle}"
                              Checked="ChkReportSection_Changed" Unchecked="ChkReportSection_Changed"/>
                    <CheckBox x:Name="ChkIcd10" 
                              Content="Diagnosen nach ICD-10" 
                              Style="{StaticResource CheckBoxStyle}"
                              Checked="ChkReportSection_Changed" Unchecked="ChkReportSection_Changed"/>
                    
                </StackPanel>
            </Border>
            
            <!-- Bereich Aktion: Recorder öffnen + Einstellungen -->
            <Border Grid.Row="1" 
                    Background="{StaticResource BackgroundPage}" 
                    BorderBrush="{StaticResource BorderLight}" 
                    BorderThickness="0,0,1,0"
                    Padding="20,24">
                <StackPanel VerticalAlignment="Center">
                    <Button x:Name="BtnOpenRecorder" 
                            Content="● Rekorder öffnen" 
                            Style="{StaticResource RecordButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="BtnOpenRecorder_Click"/>
                    <Button x:Name="BtnSettings" 
                            Content="Einstellungen / API Keys" 
                            Style="{StaticResource ControlButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,10,0,0"
                            Click="BtnSettings_Click"/>
                    <TextBlock x:Name="TxtKeyStatus" 
                               FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Platzhalter mit geometrischer Dekoration -->
            <Border Grid.Row="2" 
                    Background="{StaticResource CardHeaderBackground}" 
                    BorderBrush="{StaticResource BorderLight}" 
                    BorderThickness="0,1,1,0"
                    Padding="20,14">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentPink}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Mikrofon und Aufnahme im Aufnahme-Fenster."
                               FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- ═══════════════════════════════════════════
             Mitte: Ergebnis
             ═══════════════════════════════════════════ -->
        <Border Grid.Column="1" 
                Background="{StaticResource BackgroundPage}"
                BorderBrush="{StaticResource BorderLight}" 
                BorderThickness="0,0,1,0"
                Padding="24,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="Letzter Bericht" Style="{StaticResource SectionTitle}"/>
                    <!-- Geometrischer Akzent neben dem Titel -->
                    <Rectangle Width="20" Height="4" Fill="{StaticResource AccentYellow}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <Rectangle Width="10" Height="4" Fill="{StaticResource AccentCoral}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Visible" 
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SpResultCards" Margin="0,0,10,0">
                        <!-- Karte: Anamnese -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource CardHeaderStyle}">
                                    <Grid>
                                        <TextBlock Text="Anamnese" Style="{StaticResource CardTitle}"/>
                                        <Button x:Name="BtnCopyA" 
                                                Content="Kopieren" 
                                                Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Right"
                                                Padding="12,5"
                                                FontSize="12"
                                                Click="BtnCopyA_Click"/>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="TxtAnamnese" Style="{StaticResource ResultTextBoxStyle}" Text=""/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Karte: Befund -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource CardHeaderStyle}">
                                    <Grid>
                                        <TextBlock Text="Befund" Style="{StaticResource CardTitle}"/>
                                        <Button x:Name="BtnCopyBe" 
                                                Content="Kopieren" 
                                                Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Right"
                                                Padding="12,5"
                                                FontSize="12"
                                                Click="BtnCopyBe_Click"/>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="TxtBefund" Style="{StaticResource ResultTextBoxStyle}" Text=""/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Karte: Diagnosen / ICD-10 -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource CardHeaderStyle}">
                                    <Grid>
                                        <TextBlock Text="Diagnosen / ICD-10" Style="{StaticResource CardTitle}"/>
                                        <Button x:Name="BtnCopyN" 
                                                Content="Kopieren" 
                                                Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Right"
                                                Padding="12,5"
                                                FontSize="12"
                                                Click="BtnCopyN_Click"/>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="TxtDiagnose" Style="{StaticResource ResultTextBoxStyle}" Text=""/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- ═══════════════════════════════════════════
             Rechts: Letzte Notizen
             ═══════════════════════════════════════════ -->
        <Border Grid.Column="2" 
                Background="{StaticResource BackgroundPage}" 
                Padding="18,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Frühere Dokumentationen" Style="{StaticResource SectionTitle}" FontSize="16"/>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlue}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <ListBox x:Name="LstNotes" Grid.Row="1"
                         SelectionChanged="LstNotes_SelectionChanged"
                         Margin="0,0,0,12"
                         Background="{StaticResource CardBackground}"
                         BorderBrush="{StaticResource BorderLight}"
                         BorderThickness="1"/>
                
                <StackPanel Grid.Row="2">
                    <Button x:Name="BtnCopyNote" 
                            Content="Kopieren" 
                            Style="{StaticResource NoteActionButtonStyle}"
                            IsEnabled="False"
                            HorizontalAlignment="Stretch"
                            Click="BtnCopyNote_Click"/>
                    
                    <Button x:Name="BtnExportNote" 
                            Content="Export TXT" 
                            Style="{StaticResource NoteActionButtonStyle}"
                            IsEnabled="False"
                            HorizontalAlignment="Stretch"
                            Click="BtnExportNote_Click"/>
                    
                    <Button x:Name="BtnDeleteNote" 
                            Content="Löschen" 
                            Style="{StaticResource NoteActionButtonStyle}"
                            IsEnabled="False"
                            HorizontalAlignment="Stretch"
                            Click="BtnDeleteNote_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
