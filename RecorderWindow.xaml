<Window x:Class="ABeNT.RecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Aufnahme" Height="320" Width="840"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Mikrofon / Eingangskanal -->
        <TextBlock Grid.Row="0" Text="Eingangskanal (Mikrofon):" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox x:Name="CmbMicrophones" Grid.Row="1"
                  Padding="8,6" Margin="0,0,0,15"
                  MinHeight="28" MinWidth="200"
                  SelectionChanged="CmbMicrophones_SelectionChanged"/>
        
        <!-- Audio-Pegel -->
        <TextBlock Grid.Row="2" Text="Pegel:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ProgressBar x:Name="PbAudioLevel" Grid.Row="3"
                     Minimum="0" Maximum="100" Value="0"
                     Height="18" Margin="0,0,0,15"/>
        
        <!-- Status -->
        <TextBlock x:Name="TxtStatus" Grid.Row="4"
                   Text="Bereit – Aufnahme starten."
                   FontSize="13" Foreground="#666666"
                   VerticalAlignment="Center" TextAlignment="Center"/>
        
        <!-- Buttons: Start, Pause/Resume, Finish, Stop -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="BtnStart" Content="Aufnahme starten"
                    Width="130" Height="36" Margin="0,0,10,0"
                    Background="#D13438" Foreground="White" FontWeight="SemiBold"
                    Click="BtnStart_Click"/>
            <Button x:Name="BtnPauseResume" Content="Pause"
                    Width="90" Height="36" Margin="0,0,10,0"
                    IsEnabled="False" Click="BtnPauseResume_Click"/>
            <Button x:Name="BtnFinish" Content="Beenden &amp; Auswerten"
                    Width="160" Height="36" Margin="0,0,10,0"
                    IsEnabled="False" Click="BtnFinish_Click"/>
            <Button x:Name="BtnStop" Content="Abbrechen"
                    Width="100" Height="36"
                    Visibility="Collapsed" Click="BtnStop_Click"/>
        </StackPanel>
    </Grid>
</Window>
