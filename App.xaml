<Application x:Class="ABeNT.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- ══════════════════════════════════════════════════════════
             Bauhaus Design Tokens
             ══════════════════════════════════════════════════════════ -->

        <!-- Hintergrund und Text -->
        <SolidColorBrush x:Key="BackgroundPage"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary"           Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextSecondary"         Color="#5A7080"/>

        <!-- Primärfarben (primaer-1 bis -4) -->
        <SolidColorBrush x:Key="Accent"                Color="#558FC4"/>
        <SolidColorBrush x:Key="AccentHover"           Color="#3E7AB0"/>
        <SolidColorBrush x:Key="AccentBlue"            Color="#558FC4"/>
        <SolidColorBrush x:Key="AccentGreen"           Color="#22C55E"/>
        <SolidColorBrush x:Key="FooterBackground"      Color="#558FC4"/>

        <!-- Akzentfarbe (pink) -->
        <SolidColorBrush x:Key="AccentPink"            Color="#F072AB"/>
        <SolidColorBrush x:Key="AccentPinkHover"       Color="#D95A92"/>
        <SolidColorBrush x:Key="AccentRecord"          Color="#F072AB"/>
        <SolidColorBrush x:Key="AccentRecordHover"     Color="#D95A92"/>
        <SolidColorBrush x:Key="AccentCoral"           Color="#F072AB"/>
        <SolidColorBrush x:Key="AccentYellow"          Color="#9DCAEC"/>
        <SolidColorBrush x:Key="Highlight"             Color="#9DCAEC"/>

        <!-- Oberflächen -->
        <SolidColorBrush x:Key="CardBackground"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardHeaderBackground"  Color="#DBECF9"/>
        <SolidColorBrush x:Key="BorderLight"           Color="#C5E0F5"/>
        <SolidColorBrush x:Key="InputBackground"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBorder"           Color="#C5E0F5"/>
        <SolidColorBrush x:Key="InputBorderFocused"    Color="#558FC4"/>

        <!-- ══════════════════════════════════════════════════════════
             Globale Basis-Styles
             ══════════════════════════════════════════════════════════ -->

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="Open Sans, Segoe UI"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- ══════════════════════════════════════════════════════════
             Button-Styles (Bauhaus: abgerundete Pill-Form, Outline)
             ══════════════════════════════════════════════════════════ -->

        <!-- Primärer Akzent-Button (Outline, Mittelblau) -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="Padding"          Value="16,8"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="{StaticResource AccentHover}"/>
                                <Setter TargetName="border" Property="BorderBrush"   Value="{StaticResource AccentHover}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Gefüllter Primär-Button (Pink-Akzent für Haupt-CTAs) -->
        <Style x:Key="FilledAccentButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentPink}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource AccentPink}"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="Padding"          Value="20,10"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="{StaticResource AccentPinkHover}"/>
                                <Setter TargetName="border" Property="BorderBrush"   Value="{StaticResource AccentPinkHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="#C04E82"/>
                                <Setter TargetName="border" Property="BorderBrush"   Value="#C04E82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Record-Button (Coral, gefüllt, auffällig) -->
        <Style x:Key="RecordButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentRecord}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource AccentRecord}"/>
            <Setter Property="BorderThickness"  Value="2"/>
            <Setter Property="Padding"          Value="30,16"/>
            <Setter Property="FontSize"         Value="17"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="{StaticResource AccentRecordHover}"/>
                                <Setter TargetName="border" Property="BorderBrush"   Value="{StaticResource AccentRecordHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="#A82218"/>
                                <Setter TargetName="border" Property="BorderBrush"   Value="#A82218"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtiler / sekundärer Button (grau outline) -->
        <Style x:Key="SubtleButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="Padding"          Value="16,8"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="Normal"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="#DBECF9"/>
                                <Setter TargetName="border" Property="BorderBrush"   Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════════════════════
             TextBox Style (abgerundete Ecken, warmer Rahmen)
             ══════════════════════════════════════════════════════════ -->

        <Style x:Key="BauhausTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="CaretBrush"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputBorderFocused}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
